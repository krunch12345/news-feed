VK_TOKEN=your_vk_token_here
VK_API_VERSION=5.131
VK_REQUEST_DELAY=0.5
MAX_POSTS=1000
PAGE_SIZE=20
DATA_DIR=./data
POSTS_IMAGES_DIR=./postsImages

# Basic auth credentials (protects all endpoints). Leave empty to disable auth.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change_me

# Frontend auth (login form). Leave empty to disable.
AUTH_USER=admin
AUTH_PASS=change_me
